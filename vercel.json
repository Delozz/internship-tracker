{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "pip install -r api/requirements.txt",
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api/index.py" }],
  "functions": {
    "api/index.py": {
      "runtime": "python3.11",
      "maxDuration": 10
    }
  }
}
