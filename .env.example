# Supabase — get these from your Supabase project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...        # Used by FastAPI (read-only)
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Used by scraper only (read/write) — never expose to frontend

# API auth (optional) — when set, /api data routes require header X-API-Key: <value>.
# Leave unset for local dev to keep the API open. Set the SAME value in two places:
#   - Vercel (API):      API_KEY=<random-secret>
#   - Vercel (frontend): VITE_API_KEY=<same-random-secret>   # baked into the build
# API_KEY=replace-with-a-long-random-string

# Scraper schedule overrides (optional, defaults shown)
SCRAPER_CRON_HOUR=8
SCRAPER_CRON_MINUTE=0
SCRAPER_TIMEZONE=America/Chicago
