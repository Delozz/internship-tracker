# Supabase — get these from your Supabase project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...        # Used by FastAPI (read-only)
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Used by scraper only (read/write) — never expose to frontend

# Scraper schedule overrides (optional, defaults shown)
SCRAPER_CRON_HOUR=8
SCRAPER_CRON_MINUTE=0
SCRAPER_TIMEZONE=America/Chicago
